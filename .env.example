# Checkpoint 0 - Sentry
NEXT_PUBLIC_SENTRY_DSN=

# Checkpoint 1 - Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Checkpoint 2 - Paystack
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
# Production reminder: when `/api/paystack/webhook` is deployed on your public HTTPS domain,
# register `https://<your-production-domain>/api/paystack/webhook` in the Paystack dashboard.

# Checkpoint 3 - Resend
RESEND_API_KEY=
# Development: `CVPadi <onboarding@resend.dev>`
# Production reminder: switch to your verified sender, for example `CVPadi <hello@cvpadi.com>`
EMAIL_FROM=
EMAIL_SEQUENCE_CRON_SECRET=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Checkpoint 5 - Claude API
ANTHROPIC_API_KEY=

# Checkpoint 4 - Job scraper
# These are Supabase Edge Function secrets, not Next.js runtime vars.
# Set them with `supabase secrets set ... --project-ref <ref>`.
SENTRY_DSN=
JOB_SCRAPER_SOURCES_JSON=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_KEY=
